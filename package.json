{
  "name": "wuxianhuabu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "backend": "node local-ai-server.cjs",
    "start:local": "node local-ai-server.cjs",
    "build": "vite build",
    "bundle:report": "node scripts/bundle-size-report.mjs",
    "bundle:check": "node scripts/bundle-budget-check.mjs",
    "test": "node --test --test-concurrency=8 tests/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-include=\"src/**/*.jsx\" --test-coverage-exclude=\"src/**/*.test.*\" tests/*.test.mjs",
    "test:e2e:studio": "node scripts/studio-smoke.mjs",
    "test:e2e:studio:preview": "node scripts/run-studio-smoke-preview.mjs",
    "test:release": "npm run build && npm run bundle:check && npm run test:release-safety",
    "test:release-safety": "node scripts/release-safety-check.mjs",
    "test:desktop-smoke": "node scripts/desktop-release-smoke.mjs",
    "release:build": "npm run test:release && tauri build",
    "test:tauri-build": "node scripts/tauri-build-check.mjs",
    "test:tauri-build:run": "node scripts/tauri-build-check.mjs --run",
    "preview": "vite preview --host 127.0.0.1",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:exe": "tauri build --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
